# ─────────────────────────────────────────────────────────────
# .gitignore — Mutual Fund FAQ Assistant
# ─────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment variables (secrets) ──────────────────────────
.env
!.env.example

# ── FAISS index (large binary, regenerated via ingest.py) ────
data/faiss_index/*.faiss
data/faiss_index/*.json
# Keep the placeholder
!data/faiss_index/.gitkeep

# ── Raw scraped data (large, regenerated) ────────────────────
data/raw/

# ── Playwright browser binaries ───────────────────────────────
# (installed locally via: playwright install chromium)
# Not committed — each dev runs: .venv/Scripts/playwright install chromium

# ── BGE model cache (downloaded by HuggingFace) ──────────────
.cache/
~/.cache/huggingface/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log

# ── Pytest / coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
